---
const { project } = Astro.props;
const { title, description, thumbnail, tags, date } = project.data;
const id = project.id 
---

<a href={`/projects/${id}`} class="flex bg-slate-100 h-48 transition-transform duration-200 hover:scale-105">
  <div class="aspect-square flex justify-center items-center">
    <img src={thumbnail} alt={title} class="w-8/10 h-8/10 object-cover" />
  </div>
  <div class="p-6 flex flex-col">
    <p class="font-mono text-lg uppercase tracking-wider mb-1">{title}</p>
    <p class="font-mono text-md"><b>{date}</b>{</p>
    <p class="font-mono text-sm">{description}</p>
    <div class="mt-auto">
      <div class="flex gap-2 bottom-0">
        {tags.map(tag => (
          <span class="font-mono text-[9px] border px-2 py-0.5 uppercase">{tag}</span>
        ))}
      </div>
    </div>
  </div>
</a>


