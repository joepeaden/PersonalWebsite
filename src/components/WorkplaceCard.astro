---
const { workplace } = Astro.props;
const { title, description, thumbnail, startDate, endDate, location, tools } = workplace.data;
---

<div class="flex bg-slate-100 h-120">
  <div class="aspect-square flex mt-10 items-top justify-center w-3/10">
    <img src={thumbnail} alt={title} class="aspect-square h-7/10 object-cover" />
  </div>
  <div class="p-8 flex flex-col">
    <p class="font-mono text-2xl uppercase tracking-wider mb-1">{title}</p>
    <p class="font-mono text-md">{description}</p>
    <div class="mt-auto">
        <p class="font-mono text-md"><b>Worked from: </b>{startDate} - {endDate}</p>
        <p class="font-mono text-md mb-2"><b>Location: </b>{location}</p>
        <div class="flex gap-2 bottom-0">
        {tools.map(tool => (
          <span class="font-mono text-[9px] border px-2 py-0.5 uppercase">{tool}</span>
        ))}
      </div>
  </div>
</div>


