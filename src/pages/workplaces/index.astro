---

import WorkplaceCard from '../../components/WorkplaceCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const allWorkplaces = await getCollection('workplaces');
;
---
<BaseLayout title="Workplaces">

    <div class="mx-auto w-7xl">
        <div class="flex flex-col gap-3">
            { allWorkplaces.map(workplace => (
                <WorkplaceCard workplace={workplace} />
            ))}
        </div>
    </div>
</BaseLayout>